<Window x:Class="DegtMoney.Views.SavingGoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DegtMoney.Views"
        mc:Ignorable="d"
        Title="SavingGoalsWindow" Height="400" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Content="Добавить цель" Command="{Binding AddGoalCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Goals}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding TargetAmount, StringFormat={}{0:F2}}"/>
                <DataGridTextColumn Header="Накоплено" Binding="{Binding CurrentAmount, StringFormat={}{0:F2}}"/>
                <DataGridTextColumn Header="Дедлайн" Binding="{Binding Deadline, StringFormat=d}"/>
                <DataGridTemplateColumn Header="Прогресс">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ProgressBar Value="{Binding CurrentAmount}" Maximum="{Binding TargetAmount}" Width="100" Height="15"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Действия">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Пополнить" Command="{Binding DataContext.AddToGoalCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                <Button Content="Удалить" Command="{Binding DataContext.DeleteGoalCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
