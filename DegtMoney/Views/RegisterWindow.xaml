<Window x:Class="DegtMoney.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DegtMoney.Views"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="400" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Имя пользователя" FontWeight="Bold"/>
        <TextBox Grid.Row="1" Text="{Binding Username}" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="2" Text="Email" FontWeight="Bold"/>
        <TextBox Grid.Row="3" Text="{Binding Email}" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="4" Text="Пароль" FontWeight="Bold"/>
        <PasswordBox Grid.Row="5" x:Name="PasswordBox" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="6" Text="Подтверждение пароля" FontWeight="Bold"/>
        <PasswordBox Grid.Row="7" x:Name="ConfirmPasswordBox" Margin="0,0,0,15"/>
        <Button Grid.Row="8" Content="Зарегистрироваться" Command="{Binding RegisterCommand}" Height="30"/>
    </Grid>
</Window>
